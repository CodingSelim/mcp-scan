{
  "name": "mcp-scan",
  "version": "0.2.0",
  "description": "Security scanner for Model Context Protocol (MCP) servers — audits running servers against the OWASP MCP Top 10 and outputs console, JSON, and SARIF reports.",
  "type": "module",
  "bin": {
    "mcp-scan": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "scanner",
    "owasp",
    "sast",
    "ai",
    "llm",
    "tool-poisoning",
    "prompt-injection",
    "sarif"
  ],
  "author": "selimakl.inbox@gmail.com",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.19.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
