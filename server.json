{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.CodingSelim/mcp-scan",
  "title": "mcp-scan",
  "description": "Passive security scanner: audits MCP servers against the OWASP MCP Top 10, graded A-F.",
  "version": "0.2.1",
  "repository": {
    "url": "https://github.com/CodingSelim/mcp-scan",
    "source": "github"
  },
  "websiteUrl": "https://github.com/CodingSelim/mcp-scan",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "owasp-mcp-scan",
      "version": "0.2.1",
      "runtimeHint": "npx",
      "transport": { "type": "stdio" },
      "packageArguments": [
        { "type": "positional", "value": "--serve" }
      ]
    }
  ]
}
